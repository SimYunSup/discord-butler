# Discord bot token — REQUIRED.
# Developer Portal → your app → Bot → Reset Token. Also enable
# "Message Content Intent" under Bot → Privileged Gateway Intents.
DISCORD_TOKEN=

# Where butler state lives (per-conversation workspaces, events, session map).
# Defaults to <repo>/data if unset.
BUTLER_DATA_DIR=

# Paths to the `claude` (Claude Code CLI) and `tmux` binaries.
# Optional; default to "claude" / "tmux" on PATH.
CLAUDE_BIN=
TMUX_BIN=

# Absolute backstop (ms): max wait for a Stop hook regardless of activity.
# Default 3600000 (60 min). The idle window below is the real guard.
BUTLER_REPLY_TIMEOUT_MS=

# Idle window (ms): reject a reply only after this long with NO hook activity.
# PreToolUse/PostToolUse tool-call heartbeats reset it, so an actively-working
# bot never times out. Default 1800000 (30 min).
BUTLER_IDLE_TIMEOUT_MS=

# Default agent backend for bots that don't set their own `agent` field.
# One of: claude | kimi | glm | codex. Default: claude.
BUTLER_AGENT=

# Fallback engine chain when the primary agent fails or times out (comma-separated
# AgentKind). Tried in order; empty = no fallback. Example: kimi,glm
# Note: fallback engines also need their own auth tokens configured below.
BUTLER_FALLBACK_AGENTS=

# Kimi (Moonshot) backend — only needed if a bot (or BUTLER_AGENT) selects `kimi`.
# This runs the SAME Claude Code CLI pointed at Moonshot's Anthropic-compatible
# endpoint, so all hooks/persona keep working — only the model provider changes.
#   KIMI_BASE_URL  — Anthropic-compatible base URL (region-specific).
#                    Default: https://api.moonshot.ai/anthropic
#                    (China: https://api.moonshot.cn/anthropic)
#   KIMI_AUTH_TOKEN— your Moonshot API key (REQUIRED to use the kimi backend).
#   KIMI_MODEL     — optional model id to pin (e.g. kimi-k2.6); empty = endpoint default.
#                    Note: kimi-k2 was discontinued 2026-05-25; use kimi-k2.6 or later.
KIMI_BASE_URL=
KIMI_AUTH_TOKEN=
KIMI_MODEL=

# GLM (Z.ai / Zhipu) backend — only needed if a bot (or BUTLER_AGENT) selects `glm`.
# Same shape as Kimi: the SAME Claude Code CLI pointed at Z.ai's Anthropic-compatible
# endpoint, so all hooks/persona keep working — only the model provider changes.
# Pricing/subscription: https://z.ai/subscribe
#   GLM_BASE_URL  — Anthropic-compatible base URL.
#                   Default: https://api.z.ai/api/anthropic
#                   (China/BigModel: https://open.bigmodel.cn/api/anthropic)
#   GLM_AUTH_TOKEN— your Z.ai API key (REQUIRED to use the glm backend).
#   GLM_MODEL     — optional model id to pin (e.g. glm-5.2 or glm-5-turbo for speed);
#                   empty = endpoint default. Latest as of 2026-06: GLM-5.2.
GLM_BASE_URL=
GLM_AUTH_TOKEN=
GLM_MODEL=

# Codex backend — EXPERIMENTAL / UNVERIFIED. Only if a bot (or BUTLER_AGENT) selects
# `codex`. This "plugin" path keeps Claude Code as the driver and delegates to Codex
# via openai/codex-plugin-cc. It needs the `codex` CLI installed + authenticated
# (a paid Codex plan or OPENAI_API_KEY) and a LOCAL clone of the plugin. Untested
# end-to-end — see README "Agent backends → Codex".
#   CODEX_PLUGIN_DIR — path to your local clone of openai/codex-plugin-cc.
CODEX_PLUGIN_DIR=

# Owner gate: for bots marked `ownerOnly`, the Discord user id allowed to use them.
OWNER_DISCORD_ID=

# Optional localhost trigger webhook — an external cron can wake a bot via
# POST /trigger/<botId>. The server binds 127.0.0.1 only; an empty token
# disables it. (None of the bundled bots require this.)
BUTLER_HTTP_PORT=8787
BUTLER_TRIGGER_TOKEN=
